# ===========================================================================
# 써봄 (EssayCritiqueAI) — environment variables
# Copy to .env.local for local dev. Set the same keys in Vercel for production.
# ===========================================================================

# --- App ---
# Public base URL of the app (used for QStash callbacks, OpenAPI servers, SEO).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Database (Supabase Postgres) ---
# POOLED connection (PgBouncer, port 6543, transaction mode) for the app runtime.
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# DIRECT connection (port 5432) used only for migrations (drizzle-kit).
DIRECT_DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# --- Supabase Storage ---
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=uploads

# --- Auth ---
# Secret for signing the session JWT (HttpOnly cookie). Use a long random string.
AUTH_SECRET=

# --- AI provider selection ---
# Which provider powers the default (flash) tier: "gemini" | "deepseek" | "claude".
AI_PROVIDER=gemini
# Per-attempt timeout + retry count shared by all providers.
AI_TIMEOUT_MS=85000
AI_MAX_RETRIES=3

# --- AI: Google Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-pro

# --- AI: DeepSeek (OpenAI-compatible; text-only, no image grading) ---
# Set AI_PROVIDER=deepseek to use this instead of Gemini.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# deepseek-reasoner (R1) does NOT support JSON mode — keep pro on deepseek-chat unless you adapt parsing.
DEEPSEEK_PRO_MODEL=deepseek-chat

# --- AI: premium (pro) tier provider (optional) ---
# Which provider paid tiers use; defaults to AI_PROVIDER. "gemini" | "claude" | "deepseek".
PREMIUM_PROVIDER=
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-latest

# --- Queue: Upstash QStash ---
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# --- Payments: Toss Payments ---
TOSS_SECRET_KEY=
NEXT_PUBLIC_TOSS_CLIENT_KEY=

# --- Cron ---
# Secret required to trigger /api/cron/run manually (Vercel Cron also allowed).
CRON_SECRET=

# --- Abuse prevention (optional) ---
RECAPTCHA_SECRET_KEY=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
